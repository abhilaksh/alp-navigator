# Copy to .env and fill in real values — never commit .env
DATABASE_URL=mysql://user:password@host:3306/database
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=xxx
RAZORPAY_WEBHOOK_SECRET=xxx
BASE_URL=http://localhost:3000
AUTH_SECRET=generate-with-openssl-rand-base64-32
HAPUPPY_API_KEY=sk-hapuppy-xxx
SERPAPI_KEY=xxx
PEXELS_API_KEY=xxx
# Itinerary media uploads — images go to Cloudflare Images, PDFs go to Cloudflare R2
CLOUDFLARE_ACCOUNT_ID=xxx
CLOUDFLARE_IMAGES_API_TOKEN=xxx
R2_ACCOUNT_ID=xxx
R2_ACCESS_KEY_ID=xxx
R2_SECRET_ACCESS_KEY=xxx
R2_BUCKET_NAME=alp-navigator-uploads
R2_PUBLIC_URL_BASE=https://uploads.alptravel.co
